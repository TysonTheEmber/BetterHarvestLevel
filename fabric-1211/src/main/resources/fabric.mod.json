{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${description}",
  "authors": ["${mod_author}"],
  "license": "${license}",
  "environment": "*",
  "entrypoints": {
    "main": [
      "net.tysontheember.betterharvestlevel.fabric.BetterHarvestLevelFabric"
    ],
    "jade": [
      "net.tysontheember.betterharvestlevel.compat.jade.BHLJadePlugin"
    ]
  },
  "mixins": [
    "betterharvestlevel.mixins.json",
    "betterharvestlevel.jade.mixins.json"
  ],
  "suggests": {
    "jade": "*"
  },
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}",
    "java": ">=${java_version}"
  }
}
